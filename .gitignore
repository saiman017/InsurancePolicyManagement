# Ignore Visual Studio temporary files, build results, and user-specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore Visual Studio Code workspace settings
.vscode/
**/.env

# Ignore build outputs
**/bin/
**/obj/

# Ignore NuGet packages
*.nupkg
*.snupkg
*.nuspec

# Ignore project lock files
project.lock.json
project.fragment.lock.json
artifacts/

# Ignore Rider IDE files (optional)
.idea/
*.iml

# OS generated files
Thumbs.db
.DS_Store